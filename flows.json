    {
        "id": "271d37c73c5cb8c7",
        "type": "function",
        "z": "f6f2187d.f17ca8",
        "name": "ControlFlujo",
        "func": "// Validamos que el estado sea el de finalización (3)\nif (!msg.payload || msg.payload.estado !== 3) {\n    return null;\n}\n\nlet data = msg.payload;\n\n// IMPORTANTE: Estos nombres deben coincidir con data['id'], data['v_total']... de tu app.py\nmsg.payload = {\n    id: data.id,\n    v_total: data.v_total,\n    q_max: data.q_max,\n    ts_inicio: Date.now() - 30000, // Ajusta este cálculo si el ESP32 no lo envía\n    ts_fin: Date.now()\n};\n\nmsg.headers = {\n    \"Content-Type\": \"application/json\"\n};\n\n// URL exacta de tu endpoint en Flask\nmsg.url = \"http://flaskapp:5000/api/finalizar_prueba\";\n\nreturn msg;",
        "outputs": 1,
        "timeout": 0,
        "noerr": 0,
        "initialize": "",
        "finalize": "",
        "libs": [],
        "x": 750,
        "y": 460,
        "wires": [
