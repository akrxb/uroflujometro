    {
        "id": "c1d0314766722d0d",
        "type": "function",
        "z": "f6f2187d.f17ca8",
        "name": "ControlFlujo",
        "func": "// 1. Verificamos que el payload sea un objeto y tenga la propiedad 'id'\nif (!msg.payload || typeof msg.payload !== 'object' || msg.payload.id === undefined) {\n    return null; // Si no tiene ID, ignoramos este mensaje específico\n}\n\nlet data = msg.payload;\n\n// 2. Mapeamos los datos para InfluxDB\nmsg.payload = {\n    peso: data.p || 0,\n    caudal: data.c || 0,\n    volumen: data.v_total || 0\n};\n\n// 3. Convertimos el ID a string de forma segura\nmsg.tags = {\n    paciente_id: String(data.id)\n};\n\nreturn msg;",
        "outputs": 1,
        "timeout": 0,
        "noerr": 0,
        "initialize": "",
        "finalize": "",
        "libs": [],
        "x": 750,
        "y": 380,
